<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E4E4E4"
        android:padding="16dp">

        <ImageView
            android:id="@+id/collectionImage"
            android:layout_width="108dp"
            android:layout_height="122dp"
            android:background="#F8F8F8"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/collectionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/collectionImage"
            app:layout_constraintStart_toEndOf="@id/collectionImage"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Название подборки" />

        <TextView
            android:id="@+id/collectionDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/collectionName"
            app:layout_constraintStart_toStartOf="@id/collectionName"
            app:layout_constraintEnd_toEndOf="@id/collectionName"
            tools:text="Краткое описание подборки" />

        <TextView
            android:id="@+id/numPlaces"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/collectionDescription"
            app:layout_constraintStart_toStartOf="@id/collectionName"
            app:layout_constraintEnd_toEndOf="@id/collectionName"
            tools:text="3 места" />

        <TextView
            android:id="@+id/collectionAccessType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/numPlaces"
            app:layout_constraintStart_toStartOf="@id/collectionName"
            app:layout_constraintEnd_toEndOf="@id/collectionName"
            app:layout_constraintBottom_toBottomOf="@id/collectionImage"
            tools:text="Публичная" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>