<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="24dp">

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Доступ к геолокации"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginTop="60dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Контейнер с описанием (светло-серый фон) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#146100EC"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Мы используем ваше местоположение, чтобы показывать интересные места рядом с вами."
            android:textColor="@android:color/black"
            android:textSize="16sp" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Кнопки разрешений -->
    <Button
        android:id="@+id/btnAllow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Разрешить"
        android:backgroundTint="#6200EE"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAllowThisTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Только в этот раз"
        android:backgroundTint="@android:color/transparent"
        android:textColor="#6200EE"
        android:strokeColor="#6200EE"
        android:strokeWidth="1"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnDeny"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Запретить"
        android:backgroundTint="@android:color/transparent"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="48dp" />

</LinearLayout>