<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Поисковая строка -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/search_background"
        android:padding="20dp"
        app:queryHint="Поиск подборок и мест..." />

    <!-- Кнопки-переключатели (Подборки | Места) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/toggle_background">

        <!-- Кнопка "Подборки" -->
        <TextView
            android:id="@+id/btnCollections"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Подборки"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_left_selector"
            android:paddingVertical="8dp" />

        <!-- Кнопка "Места" -->
        <TextView
            android:id="@+id/btnPlaces"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Места"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/toggle_right_selector"
            android:paddingVertical="8dp" />

    </LinearLayout>

    <!-- КОНТЕЙНЕР СОСТОЯНИЙ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Контент с популярными подборками -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPopularCollections"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Загрузка -->
        <ProgressBar
            android:id="@+id/progressLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Ошибка -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imageErrorView"
                android:layout_width="312dp"
                android:layout_height="144dp"
                android:padding="15dp"
                app:srcCompat="@drawable/ic_map_with_point" />

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ошибка загрузки"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Проверьте подключение к интернету"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Повторить" />

        </LinearLayout>

        <!-- Пусто -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imageEmptyView"
                android:layout_width="312dp"
                android:layout_height="144dp"
                android:padding="15dp"
                app:srcCompat="@drawable/ic_map_with_point" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пока здесь пусто"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Попробуйте изменить поиск"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>