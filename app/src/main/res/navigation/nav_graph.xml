<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment1">

    <!-- Главный экран -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.togetherapp.presentation.screens.home.HomeFragment"
        android:label="Главная"
        tools:layout="@layout/fragment_home" />

    <!-- Карта -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.togetherapp.presentation.screens.map.MapFragment"
        android:label="Карта"
        tools:layout="@layout/fragment_map" />

    <!-- Личные подборки -->
    <fragment
        android:id="@+id/collectionsFragment"
        android:name="com.example.togetherapp.presentation.screens.personalcollection.PersonalCollectionsFragment"
        android:label="Мои подборки"
        tools:layout="@layout/fragment_collections">

        <!-- Переход на экран создания коллекции -->
        <action
            android:id="@+id/action_collectionsFragment_to_createCollectionFragment"
            app:destination="@id/createCollectionFragment" />
    </fragment>

    <!-- Экран создания подборки -->
    <fragment
        android:id="@+id/createCollectionFragment"
        android:name="com.example.togetherapp.presentation.screens.personalcollection.CreateCollectionFragment"
        android:label="Создать подборку"
        tools:layout="@layout/create_collection_screen" />

    <!-- Онбординг экраны -->
    <fragment
        android:id="@+id/onboardingFragment1"
        android:name="com.example.togetherapp.presentation.screens.onboarding.OnboardingFragment1"
        android:label="Onboarding 1"
        tools:layout="@layout/fragment_onboarding1">

        <action
            android:id="@+id/action_onboarding1_to_onboarding2"
            app:destination="@id/onboardingFragment2" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment2"
        android:name="com.example.togetherapp.presentation.screens.onboarding.OnboardingFragment2"
        android:label="Onboarding 2"
        tools:layout="@layout/fragment_onboarding2">

        <action
            android:id="@+id/action_onboarding2_to_onboarding3"
            app:destination="@id/onboardingFragment3" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment3"
        android:name="com.example.togetherapp.presentation.screens.onboarding.OnboardingFragment3"
        android:label="Onboarding 3"
        tools:layout="@layout/fragment_onboarding3" />

    <!-- Профиль (ВРЕМЕННО ОТКЛЮЧЕН, пока нет ViewModel и State) -->
    <!--
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.togetherapp.presentation.screens.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" />
    -->
    <fragment
        android:id="@+id/friendsFragment"
        android:name="com.example.togetherapp.presentation.screens.friends.FriendsFragment"
        android:label="Друзья"
        tools:layout="@layout/fragment_friends" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.togetherapp.presentation.screens.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile">

        <!-- Переход на экран друзей -->
        <action
            android:id="@+id/action_profileFragment_to_friendsFragment"
            app:destination="@id/friendsFragment" />

        <!-- Переход на экран коллекций -->
        <action
            android:id="@+id/action_profileFragment_to_collectionsFragment"
            app:destination="@id/collectionsFragment" />

    </fragment>

</navigation>