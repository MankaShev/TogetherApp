<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Главный экран -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.togetherapp.presentation.screens.home.HomeFragment"
        android:label="Главная"
        tools:layout="@layout/fragment_home" />

    <!-- Карта -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.togetherapp.presentation.screens.map.MapFragment"
        android:label="Карта"
        tools:layout="@layout/fragment_map" />

    <!-- Личные подборки -->
    <fragment
        android:id="@+id/collectionsFragment"
        android:name="com.example.togetherapp.presentation.screens.personalcollection.PersonalCollectionsFragment"
        android:label="Мои подборки"
        tools:layout="@layout/fragment_collections">

        <!-- Переход на экран создания коллекции -->
        <action
            android:id="@+id/action_collectionsFragment_to_createCollectionFragment"
            app:destination="@id/createCollectionFragment" />
    </fragment>

    <!-- Экран создания подборки -->
    <fragment
        android:id="@+id/createCollectionFragment"
        android:name="com.example.togetherapp.presentation.screens.personalcollection.CreateCollectionFragment"
        android:label="Создать подборку"
        tools:layout="@layout/create_collection_screen" />

    <!-- Профиль (ВРЕМЕННО ОТКЛЮЧЕН, пока нет ViewModel и State) -->
    <!--
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.togetherapp.presentation.screens.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" />
    -->

</navigation>